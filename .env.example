
# AI Skills Registry — Environment Variables

# Copy this file to .env and fill in your values
# Never commit .env to git

# SharePoint site URL (not a secret — safe to share)
SHAREPOINT_SITE_URL=https://bmgf.sharepoint.com/sites/AISkillsRegistry

# Azure App Client ID (not a secret — safe to share)
# Contact the Skills Working Group for this value
AZURE_CLIENT_ID=your-app-client-id-here

# SharePoint document library name (default: Skill Registry)
# SKILL_LIBRARY_NAME=Skill Registry

# ── For Publishers Only (sync_to_sharepoint.py) ───────────────────────────────
# These ARE secrets — never share or commit these values
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
SHAREPOINT_TENANT_ID=
